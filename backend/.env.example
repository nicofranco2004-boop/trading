# Rendi backend — environment variables
# ═══════════════════════════════════════════════════════════════════════════
# Copiá este archivo a `backend/.env` y completá los valores.
# `.env` está ignorado por git (ver .gitignore root) — nunca se commitea.
#
# En producción (Railway), estas variables se setean en el dashboard de la
# plataforma y este archivo no se usa.

# ─── AI Coach ────────────────────────────────────────────────────────────────
# Required para que el "Coach IA" de /insights funcione.
# Obtenela en: https://console.anthropic.com/settings/keys
# Modelo usado: Claude Haiku 4.5 (más barato, suficiente para chat con contexto).
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ─── Auth ────────────────────────────────────────────────────────────────────
# Required para que los tokens JWT no se reseteen al reiniciar uvicorn.
# Generar con: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# ─── Admin (opcional) ────────────────────────────────────────────────────────
# Hash SHA-256 del email admin. Si está vacío, no hay admin.
# Generar con: python3 -c "import hashlib; print(hashlib.sha256('tu@email.com'.encode()).hexdigest())"
ADMIN_EMAIL_HASH=

# ─── CORS (opcional) ─────────────────────────────────────────────────────────
# Default: localhost:5173,localhost:5174 (Vite dev). En prod agregar dominios.
# ALLOWED_ORIGINS=https://rendi.app,https://www.rendi.app

# ─── Database (opcional) ─────────────────────────────────────────────────────
# Default: ./backend/trading.db. En Railway: /data/trading.db (volume).
# DB_PATH=/data/trading.db
