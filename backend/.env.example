# Rendi backend — environment variables
# ═══════════════════════════════════════════════════════════════════════════
# Copiá este archivo a `backend/.env` y completá los valores.
# `.env` está ignorado por git (ver .gitignore root) — nunca se commitea.
#
# En producción (Railway), estas variables se setean en el dashboard de la
# plataforma y este archivo no se usa.

# ─── AI Coach ────────────────────────────────────────────────────────────────
# Required para que el "Coach IA" de /insights funcione.
# Obtenela en: https://console.anthropic.com/settings/keys
# Modelo usado: Claude Haiku 4.5 (más barato, suficiente para chat con contexto).
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ─── Auth ────────────────────────────────────────────────────────────────────
# Required para que los tokens JWT no se reseteen al reiniciar uvicorn.
# Generar con: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# ─── Admin (opcional) ────────────────────────────────────────────────────────
# Hash SHA-256 del email admin. Si está vacío, no hay admin.
# Generar con: python3 -c "import hashlib; print(hashlib.sha256('tu@email.com'.encode()).hexdigest())"
ADMIN_EMAIL_HASH=

# ─── CORS (opcional) ─────────────────────────────────────────────────────────
# Default: localhost:5173,localhost:5174 (Vite dev). En prod agregar dominios.
# ALLOWED_ORIGINS=https://rendi.finance,https://www.rendi.finance

# ─── Database (opcional) ─────────────────────────────────────────────────────
# Default: ./backend/trading.db. En Railway: /data/trading.db (volume).
# DB_PATH=/data/trading.db

# ─── Push notifications (Web Push API) ──────────────────────────────────────
# Required para que las notificaciones (earnings, drawdown, behavioral) lleguen.
# Generar el par con:
#   python3 -c "
#   from py_vapid import Vapid
#   import base64
#   v = Vapid(); v.generate_keys()
#   pn = v.public_key.public_numbers()
#   pub = base64.urlsafe_b64encode(b'\\x04' + pn.x.to_bytes(32,'big') + pn.y.to_bytes(32,'big')).rstrip(b'=').decode()
#   priv = base64.urlsafe_b64encode(v.private_key.private_numbers().private_value.to_bytes(32,'big')).rstrip(b'=').decode()
#   print('PUB=', pub); print('PRIV=', priv)
#   "
# Subject: mailto:tu@email.com — required por el spec de WebPush.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hola@rendi.finance

# ─── Mercado Pago (Billing) ─────────────────────────────────────────────────
# Required para las suscripciones Pro. Pegá las credenciales de PRUEBA del
# developer panel: https://www.mercadopago.com.ar/developers/panel
# Para producción, cambiar a las credenciales reales y MP_ENV=production.
#
# Pegá acá tu Access Token de prueba (empieza con TEST-...)
MP_ACCESS_TOKEN=
# Public Key de prueba (la usaremos en frontend cuando llegue el momento)
MP_PUBLIC_KEY=
# 'sandbox' o 'production' — define qué endpoints de MP usar y validaciones
MP_ENV=sandbox
# Webhook secret (se completa después cuando configuremos el webhook URL en MP)
MP_WEBHOOK_SECRET=
# URL base del frontend para los return_urls del checkout
# En dev: http://localhost:5173, en prod: https://rendi.finance
MP_FRONTEND_BASE_URL=http://localhost:5173

# ─── Email transaccional (Resend) ───────────────────────────────────────────
# Required para que los emails de billing se envíen realmente. Sin esto, los
# eventos se loguean a console (modo dev / no-op).
# Crear API key en: https://resend.com/api-keys
# Free tier: 100 emails/día, 3000/mes.
RESEND_API_KEY=
# From address — debe ser un dominio verificado en Resend.
# Para dev sin dominio verificado: usar 'onboarding@resend.dev' (limitado).
EMAIL_FROM=Rendi <hello@rendi.finance>
